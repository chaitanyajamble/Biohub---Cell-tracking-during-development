def _autodetect_wheelhouse(default_path):
    """Scan /---/input/*/ for a folder that actually contains the zarr
    wheel, since the exact mounted dataset-folder name can differ from
    what you'd expect from the ---.com dataset URL.

    --- mounts an attached dataset inside a notebook at
    /---/input/<dataset-slug> -- NOT /---/input/datasets/<owner>/<slug>.
    """
    search_root = "/---/input"
    if not os.path.isdir(search_root):
        return default_path
    try:
        for entry in os.listdir(search_root):
            candidate = os.path.join(search_root, entry)
            if not os.path.isdir(candidate):
                continue
            try:
                names = os.listdir(candidate)
            except OSError:
                continue
            if any(n.startswith("zarr-") and n.endswith(".whl") for n in names):
                return candidate
    except OSError:
        pass
    return default_path


