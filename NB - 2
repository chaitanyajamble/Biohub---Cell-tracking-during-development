def list_dir_safe(path):
    try:
        return sorted(os.listdir(path))
    except (FileNotFoundError, PermissionError):
        return []


def find_split_dir(root, split_names=("test", "Test", "TEST")):
    for name in split_names:
        candidate = os.path.join(root, name)
        if os.path.isdir(candidate):
            return candidate
    return root


def discover_zarr_datasets(split_dir):
    entries = list_dir_safe(split_dir)
    datasets = {}
    for e in entries:
        full = os.path.join(split_dir, e)
        if e.endswith(".zarr") and (os.path.isdir(full) or os.path.isfile(full)):
            dataset_id = e[: -len(".zarr")]
            datasets[dataset_id] = full
    return datasets


