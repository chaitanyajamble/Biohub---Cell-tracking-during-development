def open_zarr_image(path):
    """Open a .zarr path and return a lazy array-like object with shape
    (T, Z, Y, X) -- squeezing a channel axis if present."""
    z = zarr.open(path, mode="r")

    if isinstance(z, zarr.Array):
        arr = z
    else:
        candidate_keys = ["0", "raw", "image", "data", "intensities"]
        arr = None
        for k in candidate_keys:
            if k in z:
                node = z[k]
                if isinstance(node, zarr.Array):
                    arr = node
                    break
        if arr is None:
            for _, node in z.arrays(recurse=True):
                arr = node
                break
        if arr is None:
            raise ValueError(f"Could not locate an image array inside {path}")

    if arr.ndim == 5:
        return arr, True
    elif arr.ndim == 4:
        return arr, False
    else:
        raise ValueError(
            f"Unexpected array shape {arr.shape} for {path}; expected 4D "
            f"(T,Z,Y,X) or 5D (T,C,Z,Y,X)."
        )


def get_frame(arr, has_channel, t):
    frame = arr[t, 0] if has_channel else arr[t]
    return np.asarray(frame, dtype=CFG.DTYPE)


