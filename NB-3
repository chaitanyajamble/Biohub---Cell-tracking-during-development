def ensure_zarr_installed():
    """
    Makes sure `zarr` is importable. ---'s scoring container has no
    internet access, so if zarr is not already present we install it from
    the local offline-wheels dataset instead of hitting PyPI.
    """
    try:
        import zarr  # noqa: F401
        print(f"[SETUP] zarr already available (version {zarr.__version__}).")
        return True
    except ImportError:
        print("[SETUP] zarr not found - attempting an offline install.")

    if not os.path.isdir(CFG.ZARR_WHEELS_DIR):
        print(f"[SETUP] Wheel directory not found at {CFG.ZARR_WHEELS_DIR}.")
        return False

    wheels = sorted(glob.glob(os.path.join(CFG.ZARR_WHEELS_DIR, "*.whl")))
    if not wheels:
        print(f"[SETUP] No .whl files found under {CFG.ZARR_WHEELS_DIR}.")
        return False

    try:
        subprocess.check_call([
            sys.executable, "-m", "pip", "install", "--no-index",
            "--find-links", CFG.ZARR_WHEELS_DIR, "zarr",
        ])
        import zarr  # noqa: F401
        print(f"[SETUP] Offline zarr install succeeded (version {zarr.__version__}).")
        return True
    except Exception as e:
        print(f"[SETUP] Offline zarr install failed: {e}")
        return False


