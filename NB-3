def find_ground_truth_csv(train_zarr_path):
    """
    Attempts to locate a ground-truth tracks CSV next to a train zarr
    folder, trying a few common naming conventions. Returns None if nothing
    plausible is found - this check is a convenience only, never required
    for producing the submission.
    """
    base_dir = os.path.dirname(train_zarr_path)
    name = os.path.basename(train_zarr_path).replace(".zarr", "")
    candidates = [
        os.path.join(base_dir, f"{name}.csv"),
        os.path.join(base_dir, f"{name}_tracks.csv"),
        os.path.join(base_dir, "tracks", f"{name}.csv"),
        os.path.join(base_dir, name, "tracks.csv"),
    ]
    for c in candidates:
        if os.path.isfile(c):
            return c
    for c in glob.glob(os.path.join(base_dir, f"*{name}*.csv")):
        return c
    return None


def sanity_check_against_train(max_datasets=CFG.SANITY_CHECK_MAX_DATASETS):
    """
    Best-effort self-evaluation: runs the detector on t=0 of up to
    `max_datasets` training volumes and reports what fraction of
    ground-truth centroids have a predicted centroid within the
    competition's matching radius. This is a rough proxy for detector
    recall, useful as a quick cross-check - it is NOT the official edge /
    division Jaccard metric and has no bearing on submission generation.
    """
    if not ZARR_AVAILABLE:
        print("[SANITY-CHECK] Skipped (zarr unavailable).")
        return

    train_datasets = discover_zarr_datasets(CFG.COMP_DIR, "train")
    if not train_datasets:
        print("[SANITY-CHECK] Skipped (no train zarr datasets discovered).")
        return

    print("\n" + "=" * 78)
    print("Training-set sanity check (approximate recall @ matching radius)")
    print("=" * 78)

    checked = 0
    for zpath in train_datasets:
        if checked >= max_datasets or time_left() < 600:
            break
        name = os.path.basename(zpath).replace(".zarr", "")
        gt_path = find_ground_truth_csv(zpath)
        if gt_path is None:
            continue
        try:
            gt_df = pd.read_csv(gt_path)
            gt_df.columns = [c.lower() for c in gt_df.columns]
            if not {"t", "z", "y", "x"}.issubset(gt_df.columns):
                continue

            gt_t0 = gt_df[gt_df["t"] == gt_df["t"].min()]
            if gt_t0.empty:
                continue

            arr = open_zarr_volume(zpath)
            vol, stride = read_timepoint(arr, 0)
            pred_pts = detect_cells_3d(vol)
            if stride > 1 and pred_pts.size > 0:
                pred_pts[:, 1] *= stride
                pred_pts[:, 2] *= stride

            gt_pts = gt_t0[["z", "y", "x"]].to_numpy(dtype=np.float64)
            if len(pred_pts) == 0 or len(gt_pts) == 0:
                print(f"[SANITY-CHECK] {name}: nothing to compare "
                      f"(pred={len(pred_pts)}, gt={len(gt_pts)}).")
                continue

            dist = scaled_distance_matrix(gt_pts, pred_pts)
            nearest = dist.min(axis=1)
            recall = float((nearest <= CFG.MAX_LINK_DIST_UM).mean())
            print(f"[SANITY-CHECK] {name}: approx recall @ {CFG.MAX_LINK_DIST_UM}um "
                  f"= {recall:.3f} (gt_nodes={len(gt_pts)}, pred_nodes={len(pred_pts)})")
            checked += 1
            del vol
            gc.collect()
        except Exception as e:
            print(f"[SANITY-CHECK] Failed for {name}: {e}")

    if checked == 0:
        print("[SANITY-CHECK] No usable train ground-truth files were found.")
# ---------------------------------------------------------------------------
# 7. PER-DATASET DETECTION + TRACKING PIPELINE
# ---------------------------------------------------------------------------
def process_dataset(zarr_path, dataset_name):
    """
    Runs detection and frame-to-frame linking for one dataset volume,
    returning plain-dict node and edge lists ready for submission assembly.
    Robust to per-timepoint failures: a bad frame is skipped (logged) and
    tracking continues from the next successfully-read frame.
    """
    nodes, edges = [], []

    try:
        arr = open_zarr_volume(zarr_path)
    except Exception as e:
        print(f"  [WARN] Could not open {zarr_path}: {e}")
        return nodes, edges

    shape = arr.shape
    n_timepoints = shape[0] if len(shape) == 4 else 1
    print(f"  dataset={dataset_name}  shape={shape}  timepoints={n_timepoints}")

    next_node_id = 1
    prev_pts_voxel = None
    prev_node_ids = None

    for t in range(n_timepoints):
        if time_left() < 300:
            print("  [WARN] Time budget nearly exhausted - truncating remaining timepoints.")
            break

        try:
            vol, stride = read_timepoint(arr, t)
            pts = detect_cells_3d(vol)
            if stride > 1 and pts.size > 0:
                pts[:, 1] *= stride
                pts[:, 2] *= stride
            del vol
        except Exception as e:
            print(f"  [WARN] Timepoint {t} failed for {dataset_name}: {e}")
            pts = np.empty((0, 3))

        curr_ids = []
        for (z, y, x) in pts:
            nid = next_node_id
            next_node_id += 1
            nodes.append({
                "dataset": dataset_name, "node_id": nid, "t": t,
                "z": int(round(float(z))), "y": int(round(float(y))), "x": int(round(float(x))),
            })
            curr_ids.append(nid)

        if prev_pts_voxel is not None and len(prev_pts_voxel) > 0 and len(pts) > 0:
            try:
                pairs = link_frames(prev_pts_voxel, pts)
                div_pairs = detect_divisions(prev_pts_voxel, pts, pairs)
                for p_idx, c_idx in pairs + div_pairs:
                    edges.append({
                        "dataset": dataset_name,
                        "source_id": prev_node_ids[p_idx],
                        "target_id": curr_ids[c_idx],
                    })
            except Exception as e:
                print(f"  [WARN] Linking failed between t={t - 1} and t={t}: {e}")

        prev_pts_voxel = pts
        prev_node_ids = curr_ids
        gc.collect()

    return nodes, edges


# ---------------------------------------------------------------------------
# 8. SUBMISSION ASSEMBLY
# ---------------------------------------------------------------------------
def build_submission(all_nodes, all_edges, output_path=CFG.OUTPUT_CSV):
    """
    Assembles the long-format submission required by the competition:
    node rows carry (node_id, t, z, y, x) with source_id/target_id = -1,
    edge rows carry (source_id, target_id) with node_id/t/z/y/x = -1, and
    `id` is a plain consecutive row index.
    """
    cols = ["id", "dataset", "row_type", "node_id", "t", "z", "y", "x", "source_id", "target_id"]
    rows = []
    idx = 0

    for n in all_nodes:
        rows.append({
            "id": idx, "dataset": n["dataset"], "row_type": "node",
            "node_id": n["node_id"], "t": n["t"], "z": n["z"], "y": n["y"], "x": n["x"],
            "source_id": -1, "target_id": -1,
        })
        idx += 1

    for e in all_edges:
        rows.append({
            "id": idx, "dataset": e["dataset"], "row_type": "edge",
            "node_id": -1, "t": -1, "z": -1, "y": -1, "x": -1,
            "source_id": e["source_id"], "target_id": e["target_id"],
        })
        idx += 1

    df = pd.DataFrame(rows, columns=cols)
    df.to_csv(output_path, index=False)
    print(f"\nSubmission written to {output_path}")
    print(f"  total rows  : {len(df)}")
    print(f"  node rows   : {len(all_nodes)}")
    print(f"  edge rows   : {len(all_edges)}")
    print(f"  datasets    : {df['dataset'].nunique()}")
    return df


