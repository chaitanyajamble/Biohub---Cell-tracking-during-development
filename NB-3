# 9. MAIN
# ---------------------------------------------------------------------------
def main():
    print("=" * 78)
    print("Biohub - Cell Tracking During Development : Baseline Pipeline")
    print("=" * 78)

    # --- discover test datasets --------------------------------------------
    zarr_datasets = discover_zarr_datasets(CFG.COMP_DIR, "test")
    print(f"Discovered {len(zarr_datasets)} test zarr dataset(s):")
    for p in zarr_datasets:
        print(f"  - {p}")

    # --- cross-check against sample_submission.csv, if available -----------
    expected_datasets = None
    sample_sub_path = find_sample_submission()
    if sample_sub_path:
        try:
            sample_df = pd.read_csv(sample_sub_path)
            if "dataset" in sample_df.columns:
                expected_datasets = list(pd.unique(sample_df["dataset"]))
                print(f"Sample submission references {len(expected_datasets)} dataset(s).")
        except Exception as e:
            print(f"[WARN] Could not parse sample submission at {sample_sub_path}: {e}")

    # --- EDA -----------------------------------------------------------------
    try:
        run_eda(zarr_datasets)
    except Exception as e:
        print(f"[WARN] EDA step failed (non-fatal): {e}")

    # --- optional training sanity check --------------------------------------
    try:
        sanity_check_against_train()
    except Exception as e:
        print(f"[WARN] Training sanity check failed (non-fatal): {e}")

    # --- detection + tracking on the test set --------------------------------
    all_nodes, all_edges = [], []
    processed_names = set()

    if not ZARR_AVAILABLE:
        print("[ERROR] zarr is unavailable - cannot read microscopy volumes. "
              "Falling back to a placeholder submission.")
    else:
        print("\n" + "=" * 78)
        print("Detection and tracking")
        print("=" * 78)
        for zpath in zarr_datasets:
            if time_left() < 300:
                print("[WARN] Global time budget nearly exhausted - stopping dataset loop.")
                break
            dataset_name = os.path.basename(zpath).replace(".zarr", "")
            print(f"\nProcessing dataset: {dataset_name}")
            try:
                nodes, edges = process_dataset(zpath, dataset_name)
            except Exception as e:
                print(f"[WARN] Dataset {dataset_name} failed entirely: {e}")
                traceback.print_exc()
                nodes, edges = [], []
            all_nodes.extend(nodes)
            all_edges.extend(edges)
            processed_names.add(dataset_name)

    # ---dataset is represented ----------------------
    if expected_datasets:
        for name in expected_datasets:
            if name not in processed_names:
                print(f"[WARN] Dataset '{name}' missing from output - "
                      f"inserting a placeholder node so it appears in the submission.")
                all_nodes.append({"dataset": name, "node_id": 1, "t": 0, "z": 0, "y": 0, "x": 0})

    # --- last-resort fallback so a valid file is always produced --------------
    if not all_nodes and not all_edges:
        print("[WARN] No detections were produced at all - writing a minimal placeholder submission.")
        all_nodes = [{"dataset": "placeholder", "node_id": 1, "t": 0, "z": 0, "y": 0, "x": 0}]

    submission_df = build_submission(all_nodes, all_edges)
    print("\nDone.")
    return submission_df


if __name__ == "__main__":
    main()
