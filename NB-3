def discover_zarr_datasets(root_dir, split_hint):
    """
    Walks `root_dir` looking for directories ending in '.zarr'. Prefers
    folders whose parent directory name contains `split_hint` (e.g. 'test'
    or 'train'); falls back to a full recursive scan if that layout is not
    found, since the exact directory structure is not guaranteed to match
    across competition versions.
    """
    candidates = []
    if not os.path.isdir(root_dir):
        print(f"[DISCOVERY] Root directory not found: {root_dir}")
        return candidates

    if split_hint:
        for dirpath, dirnames, _ in os.walk(root_dir):
            if split_hint.lower() in os.path.basename(dirpath).lower():
                for d in dirnames:
                    if d.endswith(".zarr"):
                        candidates.append(os.path.join(dirpath, d))
        if candidates:
            return sorted(set(candidates))

    # fallback: recursive search anywhere under root_dir
    for dirpath, dirnames, _ in os.walk(root_dir):
        for d in dirnames:
            if d.endswith(".zarr"):
                candidates.append(os.path.join(dirpath, d))
    return sorted(set(candidates))


def find_sample_submission():
    """Locates sample_submission.csv anywhere under the competition dir."""
    for cand in glob.glob(os.path.join(CFG.COMP_DIR, "**", "*sample_submission*.csv"),
                           recursive=True):
        return cand
    return None


def open_zarr_volume(zarr_path):
    """
    Returns a lazily-indexable zarr array for the (t, z, y, x) or (z, y, x)
    volume at `zarr_path`. Handles both a plain zarr.Array and an OME-Zarr
    multiscale group, in which case the full-resolution level ('0') is
    preferred.
    """
    store = zarr.open(zarr_path, mode="r")
    if isinstance(store, zarr.Array):
        return store

    keys = list(store.array_keys())
    if not keys:
        raise ValueError(f"No arrays found in zarr group at {zarr_path}")
    level = "0" if "0" in keys else sorted(keys)[0]
    return store[level]


def read_timepoint(arr, t_index, max_voxels=CFG.MAX_VOXELS_PER_VOLUME):
    """
    Lazily reads a single 3D (z, y, x) volume for timepoint `t_index`,
    downsampling the y/x plane with simple striding if the full-resolution
    volume would exceed the memory budget. z is kept at full resolution
    since it is typically the smallest and most physically informative
    dimension. Returns (volume_ndarray, stride_used).
    """
    shape = arr.shape
    if len(shape) == 4:
        _, z_dim, y_dim, x_dim = shape
    elif len(shape) == 3:
        z_dim, y_dim, x_dim = shape
    else:
        raise ValueError(f"Unexpected array rank {len(shape)} for shape {shape}")

    stride = 1
    while z_dim * max(1, y_dim // stride) * max(1, x_dim // stride) > max_voxels:
        stride += 1

    if len(shape) == 4:
        vol = arr[t_index, :, ::stride, ::stride]
    else:
        vol = arr[:, ::stride, ::stride]

    vol = np.asarray(vol)
    vol = np.nan_to_num(vol, nan=0.0, posinf=0.0, neginf=0.0)
    return vol, stride


