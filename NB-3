def run_eda(zarr_datasets, max_datasets=CFG.EDA_MAX_DATASETS):
    """
    Lightweight EDA: shapes/dtypes plus one representative mid-depth slice
    and an intensity histogram per inspected dataset. Deliberately kept
    small and fast (t=0 only, capped dataset count) so it never becomes the
    runtime bottleneck against the scoring time limit.
    """
    if not ZARR_AVAILABLE or not zarr_datasets:
        print("[EDA] Skipped (zarr unavailable or no datasets discovered).")
        return

    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    print("\n" + "=" * 78)
    print("Exploratory Data Analysis")
    print("=" * 78)

    summary_rows = []
    for zpath in zarr_datasets[:max_datasets]:
        if time_left() < 600:
            print("[EDA] Time budget low - stopping EDA early.")
            break

        name = os.path.basename(zpath).replace(".zarr", "")
        try:
            arr = open_zarr_volume(zpath)
            print(f"[EDA] {name}: shape={arr.shape} dtype={arr.dtype}")
            summary_rows.append({"dataset": name, "shape": str(arr.shape), "dtype": str(arr.dtype)})

            vol, stride = read_timepoint(arr, 0)
            mid_z = vol.shape[0] // 2
            slice_img = vol[mid_z]

            fig, axes = plt.subplots(1, 2, figsize=(10, 4))
            axes[0].imshow(slice_img, cmap="gray")
            axes[0].set_title(f"{name}  t=0, z={mid_z} (stride={stride})")
            axes[0].axis("off")
            axes[1].hist(vol.ravel(), bins=100, color="steelblue")
            axes[1].set_yscale("log")
            axes[1].set_title("Intensity histogram (t=0)")
            fig.tight_layout()

            out_png = os.path.join(CFG.WORK_DIR, f"eda_{name}.png")
            fig.savefig(out_png, dpi=100)
            plt.close(fig)
            print(f"[EDA] figure saved -> {out_png}")

            del vol
            gc.collect()
        except Exception as e:
            print(f"[EDA] Failed for {zpath}: {e}")

    if summary_rows:
        print("\n[EDA] Dataset summary:")
        print(pd.DataFrame(summary_rows).to_string(index=False))


# ---------------------------------------------------------------------------
# 4. DETECTION
# ---------------------------------------------------------------------------
def detect_cells_3d(volume, min_voxels=CFG.MIN_COMPONENT_VOXELS,
                     percentile=CFG.INTENSITY_PERCENTILE):
    
    
    
    from scipy import ndimage as ndi

    if volume is None or volume.size == 0:
        return np.empty((0, 3), dtype=np.float64)

    vol = volume.astype(np.float32, copy=False)
    thresh = np.percentile(vol, percentile)
    mask = vol > thresh
    if not mask.any():
        return np.empty((0, 3), dtype=np.float64)

    structure = np.ones((3, 3, 3), dtype=np.uint8)
    labeled, n_labels = ndi.label(mask, structure=structure)
    if n_labels == 0:
        return np.empty((0, 3), dtype=np.float64)

    sizes = ndi.sum(mask, labeled, index=np.arange(1, n_labels + 1))
    keep_labels = np.nonzero(sizes >= min_voxels)[0] + 1
    if keep_labels.size == 0:
        return np.empty((0, 3), dtype=np.float64)

    centroids = ndi.center_of_mass(vol, labeled, index=keep_labels)
    return np.asarray(centroids, dtype=np.float64)


# ---------------------------------------------------------------------------
# 5. TRACKING / LINKING
# ---------------------------------------------------------------------------
def scaled_distance_matrix(pts_a, pts_b):
    """
    Pairwise Euclidean distance matrix in physical microns, applying the
    competition's voxel scale (z=1.625, y=x=0.40625 um/voxel).
    """
    scale = np.array([CFG.SCALE_Z, CFG.SCALE_Y, CFG.SCALE_X])
    a = pts_a * scale
    b = pts_b * scale
    diff = a[:, None, :] - b[None, :, :]
    return np.sqrt((diff ** 2).sum(axis=-1))


def link_frames(prev_pts, curr_pts, max_dist=CFG.MAX_LINK_DIST_UM):
    """
    Optimal one-to-one assignment between consecutive frames via the
    Hungarian algorithm, gated at `max_dist` microns (the competition's own
    matching radius). Returns a list of (prev_idx, curr_idx) index pairs.
    """
    from scipy.optimize import linear_sum_assignment

    if len(prev_pts) == 0 or len(curr_pts) == 0:
        return []

    dist = scaled_distance_matrix(prev_pts, curr_pts)
    row_ind, col_ind = linear_sum_assignment(dist)
    return [(r, c) for r, c in zip(row_ind, col_ind) if dist[r, c] <= max_dist]


def detect_divisions(prev_pts, curr_pts, existing_pairs,
                      max_dist=CFG.MAX_LINK_DIST_UM, ratio=CFG.DIVISION_DIST_RATIO):
    """
    Heuristic division detector. The one-to-one Hungarian linkage above
    cannot itself produce a node with two outgoing edges, so any curr-frame
    point left unmatched is checked against its nearest prev-frame point
    (within a relaxed distance gate). If that prev-frame point is already
    matched to a different curr-frame point, adding this second edge turns
    it into a division node, matching the competition's definition of a
    division (a node with two or more outgoing edges).
    """
    if len(prev_pts) == 0 or len(curr_pts) == 0:
        return []

    matched_curr = {c for _, c in existing_pairs}
    unmatched_curr = [c for c in range(len(curr_pts)) if c not in matched_curr]
    if not unmatched_curr:
        return []

    dist = scaled_distance_matrix(prev_pts, curr_pts)
    extra_pairs = []
    for c in unmatched_curr:
        p_best = int(np.argmin(dist[:, c]))
        d_best = dist[p_best, c]
        if d_best <= max_dist * ratio:
            extra_pairs.append((p_best, c))
    return extra_pairs


