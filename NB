def _autodetect_wheelhouse(default_path):
    """Scan /download/*/ for a folder that actually contains the zarr
    wheel, since the exact mounted dataset-folder name can differ from
    what you'd expect from the dataset .

    IMPORTANT:  Attached dataset inside a notebook at
    /download/<dataset> .
    The latter is only the *website* URL for the dataset's page; it is not
    a real path inside the notebook's filesystem, so searching there always
    came back empty and silently fell through to the (also malformed,
    non-absolute) default_path. That is what broke offline installs during
    the actual (internet-disabled) submission rerun even though the
    notebook could still reach PyPI -- and therefore looked fine -- while
    editing interactively with internet enabled.
    """
    search_root = "/download/--"
    if not os.path.isdir(search_root):
        return default_path
    try:
        for entry in os.listdir(search_root):
            candidate = os.path.join(search_root, entry)
            if not os.path.isdir(candidate):
                continue
            try:
                names = os.listdir(candidate)
            except OSError:
                continue
            if any(n.startswith("zarr-") and n.endswith(".whl") for n in names):
                return candidate
    except OSError:
        pass
    return default_path


