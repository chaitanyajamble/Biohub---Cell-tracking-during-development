def has_internet(timeout=3.0):
    """Cheap connectivity probe so error messages can state the real cause
    instead of guessing."""
    import socket
    try:
        socket.setdefaulttimeout(timeout)
        socket.create_connection(("pypi.org", 443))
        return True
    except OSError:
        return False


def ensure_package(import_name, pip_name=None):
    """Import a package, self-installing it if missing.

    Install order:
      1. Plain `import` (covers packages already preinstalled in the image).
      2. Offline wheelhouse install, if CFG_OFFLINE_WHEELHOUSE exists (this
         is what lets the final, internet-disabled submission run succeed).
      3. Regular online `pip install` (only works while internet is
         enabled, i.e. during interactive development, not at submission
         time).

    Returns the imported module, or None if every strategy failed.
    """
    pip_name = pip_name or import_name
    try:
        return importlib.import_module(import_name)
    except ImportError:
        pass

    offline_dir = os.environ.get("OFFLINE_WHEELHOUSE", CFG_OFFLINE_WHEELHOUSE)
    if offline_dir and os.path.isdir(offline_dir):
        cmd = [
            sys.executable, "-m", "pip", "install", "--quiet", "--no-index",
            f"--find-links={offline_dir}", pip_name,
        ]
        try:
            subprocess.check_call(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            importlib.invalidate_caches()
            return importlib.import_module(import_name)
        except Exception:
            pass

    if has_internet():
        cmd = [sys.executable, "-m", "pip", "install", "--quiet", pip_name]
        try:
            subprocess.check_call(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            importlib.invalidate_caches()
            return importlib.import_module(import_name)
        except Exception:
            pass

    return None


